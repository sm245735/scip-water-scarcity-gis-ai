# 論文原始大資料不進 Git（重要！）
data/
*.csv

# 但這些樣本要進 Git（進 Git 展示用）
!data_samples/*.csv
*.xlsx
*.zip

# Python 垃圾檔
__pycache__/
*.pyc
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Docker
.docker/
.dockerignore

# 虛擬環境
venv/
.venv/

# 環境變數（存資料庫密碼，不能公開）
.env

# === 排程腳本不進 Git（安全考量）===
**/spawn_coder_for_review.py
**/check_todos.py
**/project_health_check.py
**/memory_maintenance.py
