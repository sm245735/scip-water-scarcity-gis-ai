# ================================================
# 論文資料庫環境變數範例 (.env.example)
# 複製此檔案為 .env，填入實際值
# .env 已經過 .gitignore 排除，不會被 commit
# ================================================

# ---------- PostgreSQL / PostGIS 資料庫連線 ----------
# 主機（Docker Compose 內部網路中通常為 "db"，或 localhost/127.0.0.1）
DB_HOST=db

# 連接埠（PostgreSQL 預設為 5432）
DB_PORT=5432

# 資料庫名稱
DB_NAME=thesis_analysis

# 資料庫用戶名稱
DB_USER=sm245735

# 資料庫密碼（重要！請勿 commit 真實密碼）
DB_PASSWORD=your_database_password_here
